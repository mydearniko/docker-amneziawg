#!/usr/bin/with-contenv bash
# shellcheck shell=bash

unset AWG_CONFS
rm -rf /run/activeconfs
# Restore any conf backups left from a previous crashed run
for bak in /config/wg_confs/*.conf.awgbak; do
    [[ -f "${bak}" ]] && mv "${bak}" "${bak%.awgbak}"
done
# Enumerate interfaces
for awgconf in /config/wg_confs/*.conf; do
    if grep -q "\[Interface\]" "${awgconf}"; then
        echo "**** Found AWG conf ${awgconf}, adding to list ****"
        AWG_CONFS+=("${awgconf}")
    else
        echo "**** Found AWG conf ${awgconf}, but it doesn't seem to be valid, skipping. ****"
    fi
done

if [[ -z "${AWG_CONFS[*]}" ]]; then
    echo "**** No valid tunnel config found. Please create a valid config and restart the container ****"
    if [[ "${KILL_SWITCH,,}" == "true" ]]; then
        echo "**** Kill switch is active, removing default route to prevent traffic leaks ****"
        ip route del default
    fi
    exit 0
fi

unset FAILED
for tunnel in "${AWG_CONFS[@]}"; do
    echo "**** Activating tunnel ${tunnel} ****"
    # Make sysctl commands in PostUp non-fatal to prevent tunnel failure
    # when container lacks write access to /proc/sys (Docker default).
    # The sysctls will be attempted but won't abort awg-quick on permission denied.
    sed -i.awgbak '/^[[:space:]]*PostUp.*sysctl/s/$/ || true/' "${tunnel}"
    if ! awg-quick up "${tunnel}"; then
        [[ -f "${tunnel}.awgbak" ]] && mv "${tunnel}.awgbak" "${tunnel}"
        FAILED="${tunnel}"
        break
    fi
    [[ -f "${tunnel}.awgbak" ]] && mv "${tunnel}.awgbak" "${tunnel}"
done

if [[ -z "${FAILED}" ]]; then
    declare -p AWG_CONFS > /run/activeconfs
    echo "**** All tunnels are now active ****"
else
    echo "**** Tunnel ${FAILED} failed, will stop all others! ****"
    for tunnel in "${AWG_CONFS[@]}"; do
        if [[ "${tunnel}" = "${FAILED}" ]]; then
            break
        else
            echo "**** Disabling tunnel ${tunnel} ****"
            awg-quick down "${tunnel}" || :
        fi
    done
    if [[ "${KILL_SWITCH,,}" == "true" ]]; then
        echo "**** Kill switch is active, removing default route to prevent traffic leaks ****"
        ip route del default
    fi
    echo "**** All tunnels are now down. Please fix the tunnel config ${FAILED} and restart the container ****"
fi
